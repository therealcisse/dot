#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

usage() {
  echo "Usage: ./install <package...>"
  echo "Packages: $(find . -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | tr '\n' ' ')"
}

resolve_target() {
  local stowrc="$1"
  local target=".."

  if [ -f "$stowrc" ]; then
    local configured_target
    configured_target="$(sed -n 's/^--target=//p' "$stowrc" | head -1)"

    if [ -n "$configured_target" ]; then
      target="${configured_target/#\~/$HOME}"
    fi
  fi

  echo "$target"
}

if [ $# -eq 0 ]; then
  usage
  exit 1
fi

for pkg in "$@"; do
  if [ ! -d "$pkg" ]; then
    echo "Package '$pkg' not found"
    exit 1
  fi

  stowrc=".stowrc"

  if [ -f "$pkg/.stowrc" ]; then
    stowrc="$pkg/.stowrc"
  fi

  target="$(resolve_target "$stowrc")"

  stow -R --no-folding -v --target="$target" "$pkg"
  echo "Installed $pkg"
done
